param(
    [string]$Root = "D:\us-tech-quant",
    [switch]$UseYFinance,
    [int]$MinCount = 20,
    [double]$TopFraction = 0.30
)

$ErrorActionPreference = "Stop"

function Get-ReadFirstValue {
    param(
        [string]$Path,
        [string]$Key
    )

    if (-not (Test-Path $Path)) {
        return ""
    }

    $Target = $Key.Trim()
    if (-not $Target.EndsWith(":")) {
        $Target = $Target + ":"
    }

    $Lines = Get-Content $Path -Encoding UTF8

    for ($i = 0; $i -lt $Lines.Count; $i++) {
        $Line = $Lines[$i].Trim()

        # Format A: KEY: VALUE
        if ($Line.StartsWith($Target)) {
            $Value = $Line.Substring($Target.Length).Trim()
            if ($Value -ne "") {
                return $Value
            }
        }

        # Format B:
        # KEY:
        # VALUE
        if ($Line -eq $Target) {
            for ($j = $i + 1; $j -lt $Lines.Count; $j++) {
                $Next = $Lines[$j].Trim()
                if ($Next -ne "") {
                    return $Next
                }
            }
        }
    }

    return ""
}

function To-IntSafe {
    param([string]$Value)

    $n = 0
    if ([int]::TryParse($Value, [ref]$n)) {
        return $n
    }
    return 0
}

function Invoke-ChildCommand {
    param(
        [string]$Name,
        [string[]]$CommandArgs
    )

    $Start = Get-Date
    Write-Host ""
    Write-Host "=== STEP START: $Name ==="

    try {
        $Output = & powershell @CommandArgs 2>&1
        $ExitCode = $LASTEXITCODE

        foreach ($Line in $Output) {
            Write-Host $Line
        }

        if ($ExitCode -ne 0) {
            throw "Child command failed with exit code $ExitCode"
        }

        $End = Get-Date
        $Seconds = [Math]::Round(($End - $Start).TotalSeconds, 3)

        Write-Host "=== STEP OK: $Name | ${Seconds}s ==="

        return [PSCustomObject]@{
            step = $Name
            status = "OK"
            seconds = $Seconds
            error = ""
        }
    }
    catch {
        $End = Get-Date
        $Seconds = [Math]::Round(($End - $Start).TotalSeconds, 3)
        $ErrText = $_.Exception.Message

        Write-Host "=== STEP FAIL: $Name | ${Seconds}s ==="
        Write-Host $ErrText

        return [PSCustomObject]@{
            step = $Name
            status = "FAIL"
            seconds = $Seconds
            error = $ErrText
        }
    }
}

Write-Host ""
Write-Host "=== V18.10C-R1 FACTOR + WEIGHT RESEARCH DAILY CHAIN START ==="
Write-Host "ROOT: $Root"
Write-Host "USE_YFINANCE: $UseYFinance"
Write-Host "MIN_COUNT: $MinCount"
Write-Host "TOP_FRACTION: $TopFraction"

$OutDir = Join-Path $Root "outputs\v18\weight_research"
New-Item -ItemType Directory -Force -Path $OutDir | Out-Null

$StepsPath = Join-Path $OutDir "V18_10C_R1_CURRENT_FACTOR_WEIGHT_RESEARCH_DAILY_CHAIN_STEPS.csv"
$ReportPath = Join-Path $OutDir "V18_10C_R1_CURRENT_FACTOR_WEIGHT_RESEARCH_DAILY_CHAIN_REPORT.md"
$ReadFirstPath = Join-Path $OutDir "V18_10C_R1_READ_FIRST.txt"

$ForwardFiller = Join-Path $Root "scripts\v18\run_v18_9B_forward_return_filler.ps1"
$CoverageAudit = Join-Path $Root "scripts\v18\run_v18_10A_factor_registry_coverage_audit.ps1"
$MaturityMonitor = Join-Path $Root "scripts\v18\run_v18_10B_R1_forward_return_maturity_monitor.ps1"
$Effectiveness = Join-Path $Root "scripts\v18\run_v18_10B_factor_effectiveness_backtest.ps1"
$WeightResearch = Join-Path $Root "scripts\v18\run_v18_10C_weight_research_engine.ps1"

foreach ($Required in @($ForwardFiller, $CoverageAudit, $MaturityMonitor, $Effectiveness, $WeightResearch)) {
    if (-not (Test-Path $Required)) {
        throw "Missing required script: $Required"
    }
}

$StepResults = @()

$ForwardArgs = @("-NoProfile", "-ExecutionPolicy", "Bypass", "-File", $ForwardFiller)
if ($UseYFinance) {
    $ForwardArgs += "-UseYFinance"
}
$StepResults += Invoke-ChildCommand "V18.9B forward return filler" $ForwardArgs

$CoverageArgs = @("-NoProfile", "-ExecutionPolicy", "Bypass", "-File", $CoverageAudit)
$StepResults += Invoke-ChildCommand "V18.10A factor registry coverage audit" $CoverageArgs

$MaturityArgs = @("-NoProfile", "-ExecutionPolicy", "Bypass", "-File", $MaturityMonitor, "-MinCount", "$MinCount")
$StepResults += Invoke-ChildCommand "V18.10B-R1 forward return maturity monitor" $MaturityArgs

$EffectivenessArgs = @("-NoProfile", "-ExecutionPolicy", "Bypass", "-File", $Effectiveness, "-MinCount", "$MinCount", "-TopFraction", "$TopFraction")
$StepResults += Invoke-ChildCommand "V18.10B factor effectiveness backtest" $EffectivenessArgs

$WeightArgs = @("-NoProfile", "-ExecutionPolicy", "Bypass", "-File", $WeightResearch, "-MinCount", "$MinCount", "-TopFraction", "$TopFraction")
$StepResults += Invoke-ChildCommand "V18.10C weight research engine" $WeightArgs

$StepResults | Export-Csv -Path $StepsPath -NoTypeInformation -Encoding UTF8

$FailCount = @($StepResults | Where-Object { $_.status -ne "OK" }).Count
$TotalSeconds = [Math]::Round((@($StepResults | Measure-Object -Property seconds -Sum).Sum), 3)

$FillerReadFirst = Join-Path $Root "outputs\v18\simulation\V18_9B_READ_FIRST.txt"
$CoverageReadFirst = Join-Path $Root "outputs\v18\factor_registry\V18_10A_READ_FIRST.txt"
$MaturityReadFirst = Join-Path $Root "outputs\v18\factor_research\V18_10B_R1_READ_FIRST.txt"
$EffectivenessReadFirst = Join-Path $Root "outputs\v18\factor_research\V18_10B_READ_FIRST.txt"
$WeightReadFirst = Join-Path $Root "outputs\v18\weight_research\V18_10C_READ_FIRST.txt"

$ForwardStatus = Get-ReadFirstValue $FillerReadFirst "STATUS:"
$YFinanceStatus = Get-ReadFirstValue $FillerReadFirst "YFINANCE_STATUS:"
$TrackerRows = Get-ReadFirstValue $FillerReadFirst "TRACKER_ROWS:"
$FilledCells = Get-ReadFirstValue $FillerReadFirst "FILLED_CELLS_THIS_RUN:"
$PendingCells = Get-ReadFirstValue $FillerReadFirst "PENDING_CELLS_THIS_RUN:"

$OfficialCandidateCaptured = Get-ReadFirstValue $CoverageReadFirst "OFFICIAL_CANDIDATE_CAPTURED_COUNT:"
$ValidationLabelCaptured = Get-ReadFirstValue $CoverageReadFirst "VALIDATION_LABEL_CAPTURED_COUNT:"

$ReadyHorizonCount = Get-ReadFirstValue $MaturityReadFirst "READY_HORIZON_COUNT:"
$TotalLabelNonblank = Get-ReadFirstValue $MaturityReadFirst "TOTAL_LABEL_NONBLANK_COUNT:"
$TotalMatureBlank = Get-ReadFirstValue $MaturityReadFirst "TOTAL_MATURE_BUT_LABEL_BLANK_COUNT:"

$OkEvaluatedRows = Get-ReadFirstValue $EffectivenessReadFirst "OK_EVALUATED_ROWS:"
$InsufficientRows = Get-ReadFirstValue $EffectivenessReadFirst "INSUFFICIENT_SAMPLE_ROWS:"
$NoDataRows = Get-ReadFirstValue $EffectivenessReadFirst "NO_DATA_ROWS:"

$WeightResearchStatus = Get-ReadFirstValue $WeightReadFirst "STATUS:"
$WeightCandidateCount = Get-ReadFirstValue $WeightReadFirst "WEIGHT_CANDIDATE_COUNT:"
$WeightReadyHorizonCount = Get-ReadFirstValue $WeightReadFirst "READY_HORIZON_COUNT:"
$WeightOkEvaluatedRows = Get-ReadFirstValue $WeightReadFirst "OK_EVALUATED_ROWS:"
$WeightNoDataRows = Get-ReadFirstValue $WeightReadFirst "NO_DATA_ROWS:"
$WeightPromotionPermission = Get-ReadFirstValue $WeightReadFirst "PROMOTION_PERMISSION:"

if ($FailCount -eq 0) {
    $Status = "OK_FACTOR_WEIGHT_RESEARCH_DAILY_CHAIN_READY"
}
else {
    $Status = "FAIL_FACTOR_WEIGHT_RESEARCH_DAILY_CHAIN"
}

$ReadyInt = To-IntSafe $ReadyHorizonCount
$WeightOkInt = To-IntSafe $WeightOkEvaluatedRows

if ($ReadyInt -gt 0 -and $WeightOkInt -gt 0) {
    $ResearchPermission = "RESEARCH_REVIEW_ALLOWED_BUT_NO_AUTO_PROMOTION"
}
else {
    $ResearchPermission = "HOLD_NO_WEIGHT_ACTION"
}

$ReadFirstLines = @(
    "V18.10C-R1 FACTOR + WEIGHT RESEARCH DAILY CHAIN READ FIRST",
    "",
    "STATUS:",
    $Status,
    "",
    "MODE:",
    "SHADOW_ONLY_NO_BLACK_BOX_FACTOR_AND_WEIGHT_RESEARCH_CHAIN",
    "",
    "OFFICIAL_DECISION_IMPACT:",
    "NONE",
    "",
    "AUTO_WEIGHT_CHANGE:",
    "DISABLED",
    "",
    "AUTO_PROMOTION:",
    "DISABLED",
    "",
    "AUTO_TRADE:",
    "DISABLED",
    "",
    "USE_YFINANCE:",
    "$UseYFinance",
    "",
    "TOTAL_SECONDS:",
    "$TotalSeconds",
    "",
    "FAIL_COUNT:",
    "$FailCount",
    "",
    "FORWARD_FILLER_STATUS:",
    "$ForwardStatus",
    "",
    "YFINANCE_STATUS:",
    "$YFinanceStatus",
    "",
    "TRACKER_ROWS:",
    "$TrackerRows",
    "",
    "FILLED_CELLS_THIS_RUN:",
    "$FilledCells",
    "",
    "PENDING_CELLS_THIS_RUN:",
    "$PendingCells",
    "",
    "OFFICIAL_CANDIDATE_CAPTURED_COUNT:",
    "$OfficialCandidateCaptured",
    "",
    "VALIDATION_LABEL_CAPTURED_COUNT:",
    "$ValidationLabelCaptured",
    "",
    "READY_HORIZON_COUNT:",
    "$ReadyHorizonCount",
    "",
    "TOTAL_LABEL_NONBLANK_COUNT:",
    "$TotalLabelNonblank",
    "",
    "TOTAL_MATURE_BUT_LABEL_BLANK_COUNT:",
    "$TotalMatureBlank",
    "",
    "FACTOR_OK_EVALUATED_ROWS:",
    "$OkEvaluatedRows",
    "",
    "FACTOR_INSUFFICIENT_SAMPLE_ROWS:",
    "$InsufficientRows",
    "",
    "FACTOR_NO_DATA_ROWS:",
    "$NoDataRows",
    "",
    "WEIGHT_RESEARCH_STATUS:",
    "$WeightResearchStatus",
    "",
    "WEIGHT_CANDIDATE_COUNT:",
    "$WeightCandidateCount",
    "",
    "WEIGHT_READY_HORIZON_COUNT:",
    "$WeightReadyHorizonCount",
    "",
    "WEIGHT_OK_EVALUATED_ROWS:",
    "$WeightOkEvaluatedRows",
    "",
    "WEIGHT_NO_DATA_ROWS:",
    "$WeightNoDataRows",
    "",
    "WEIGHT_PROMOTION_PERMISSION:",
    "$WeightPromotionPermission",
    "",
    "RESEARCH_PERMISSION:",
    "$ResearchPermission",
    "",
    "STEPS:",
    "$StepsPath",
    "",
    "REPORT:",
    "$ReportPath",
    "",
    "READ_FIRST:",
    "$ReadFirstPath",
    "",
    "NEXT_STEP:",
    "If RESEARCH_PERMISSION is HOLD_NO_WEIGHT_ACTION, do not adjust weights.",
    "Keep running this daily chain until forward-return labels mature.",
    "Only review weight candidates after factor and weight evaluation rows become OK_EVALUATED."
)

Set-Content -Path $ReadFirstPath -Value $ReadFirstLines -Encoding UTF8

$ReportLines = @(
    "# V18.10C-R1 Factor + Weight Research Daily Chain",
    "",
    "Generated: " + (Get-Date -Format "yyyy-MM-dd HH:mm:ss"),
    "",
    "## 1. Status",
    "",
    "- STATUS: " + $Status,
    "- MODE: SHADOW_ONLY_NO_BLACK_BOX_FACTOR_AND_WEIGHT_RESEARCH_CHAIN",
    "- OFFICIAL_DECISION_IMPACT: NONE",
    "- AUTO_WEIGHT_CHANGE: DISABLED",
    "- AUTO_PROMOTION: DISABLED",
    "- AUTO_TRADE: DISABLED",
    "- TOTAL_SECONDS: " + $TotalSeconds,
    "- FAIL_COUNT: " + $FailCount,
    "",
    "## 2. Forward return filler",
    "",
    "- FORWARD_FILLER_STATUS: " + $ForwardStatus,
    "- YFINANCE_STATUS: " + $YFinanceStatus,
    "- TRACKER_ROWS: " + $TrackerRows,
    "- FILLED_CELLS_THIS_RUN: " + $FilledCells,
    "- PENDING_CELLS_THIS_RUN: " + $PendingCells,
    "",
    "## 3. Factor coverage",
    "",
    "- OFFICIAL_CANDIDATE_CAPTURED_COUNT: " + $OfficialCandidateCaptured,
    "- VALIDATION_LABEL_CAPTURED_COUNT: " + $ValidationLabelCaptured,
    "",
    "## 4. Maturity",
    "",
    "- READY_HORIZON_COUNT: " + $ReadyHorizonCount,
    "- TOTAL_LABEL_NONBLANK_COUNT: " + $TotalLabelNonblank,
    "- TOTAL_MATURE_BUT_LABEL_BLANK_COUNT: " + $TotalMatureBlank,
    "",
    "## 5. Factor effectiveness",
    "",
    "- FACTOR_OK_EVALUATED_ROWS: " + $OkEvaluatedRows,
    "- FACTOR_INSUFFICIENT_SAMPLE_ROWS: " + $InsufficientRows,
    "- FACTOR_NO_DATA_ROWS: " + $NoDataRows,
    "",
    "## 6. Weight research",
    "",
    "- WEIGHT_RESEARCH_STATUS: " + $WeightResearchStatus,
    "- WEIGHT_CANDIDATE_COUNT: " + $WeightCandidateCount,
    "- WEIGHT_READY_HORIZON_COUNT: " + $WeightReadyHorizonCount,
    "- WEIGHT_OK_EVALUATED_ROWS: " + $WeightOkEvaluatedRows,
    "- WEIGHT_NO_DATA_ROWS: " + $WeightNoDataRows,
    "- WEIGHT_PROMOTION_PERMISSION: " + $WeightPromotionPermission,
    "",
    "## 7. Guardrail",
    "",
    "- RESEARCH_PERMISSION: " + $ResearchPermission,
    "",
    "No automatic factor or weight changes are allowed in this chain.",
    "",
    "## 8. Step results",
    "",
    "| step | status | seconds | error |",
    "|---|---|---:|---|"
)

foreach ($s in $StepResults) {
    $safeErr = "$($s.error)".Replace("|", "/")
    $ReportLines += "| $($s.step) | $($s.status) | $($s.seconds) | $safeErr |"
}

$ReportLines += @(
    "",
    "## 9. Outputs",
    "",
    "- STEPS: " + $StepsPath,
    "- REPORT: " + $ReportPath,
    "- READ_FIRST: " + $ReadFirstPath
)

Set-Content -Path $ReportPath -Value $ReportLines -Encoding UTF8

Write-Host ""
Write-Host "=== V18.10C-R1 FACTOR + WEIGHT RESEARCH DAILY CHAIN READY ==="
Write-Host "STATUS: $Status"
Write-Host "MODE: SHADOW_ONLY_NO_BLACK_BOX_FACTOR_AND_WEIGHT_RESEARCH_CHAIN"
Write-Host "OFFICIAL_DECISION_IMPACT: NONE"
Write-Host "AUTO_WEIGHT_CHANGE: DISABLED"
Write-Host "AUTO_PROMOTION: DISABLED"
Write-Host "AUTO_TRADE: DISABLED"
Write-Host "TOTAL_SECONDS: $TotalSeconds"
Write-Host "FAIL_COUNT: $FailCount"
Write-Host "FORWARD_FILLER_STATUS: $ForwardStatus"
Write-Host "YFINANCE_STATUS: $YFinanceStatus"
Write-Host "TRACKER_ROWS: $TrackerRows"
Write-Host "FILLED_CELLS_THIS_RUN: $FilledCells"
Write-Host "PENDING_CELLS_THIS_RUN: $PendingCells"
Write-Host "READY_HORIZON_COUNT: $ReadyHorizonCount"
Write-Host "TOTAL_LABEL_NONBLANK_COUNT: $TotalLabelNonblank"
Write-Host "FACTOR_OK_EVALUATED_ROWS: $OkEvaluatedRows"
Write-Host "FACTOR_NO_DATA_ROWS: $NoDataRows"
Write-Host "WEIGHT_RESEARCH_STATUS: $WeightResearchStatus"
Write-Host "WEIGHT_CANDIDATE_COUNT: $WeightCandidateCount"
Write-Host "WEIGHT_OK_EVALUATED_ROWS: $WeightOkEvaluatedRows"
Write-Host "WEIGHT_NO_DATA_ROWS: $WeightNoDataRows"
Write-Host "WEIGHT_PROMOTION_PERMISSION: $WeightPromotionPermission"
Write-Host "RESEARCH_PERMISSION: $ResearchPermission"
Write-Host "STEPS: $StepsPath"
Write-Host "REPORT: $ReportPath"
Write-Host "READ_FIRST: $ReadFirstPath"
Write-Host ""

if ($FailCount -gt 0) {
    throw "V18.10C-R1 completed with failing step(s). Check: $StepsPath"
}
