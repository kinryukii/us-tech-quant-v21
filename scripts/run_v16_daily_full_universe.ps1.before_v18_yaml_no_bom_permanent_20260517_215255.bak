param(
    [switch]$UseYFinance,
    [switch]$SkipDaily,
    [switch]$SkipOfficialDaily
)

$ErrorActionPreference = "Stop"

$Root = "D:\us-tech-quant"
$Stamp = Get-Date -Format "yyyyMMdd_HHmmss"

Write-Host ""
Write-Host "=== V16 FULL UNIVERSE COMPAT SHIM NON-RECURSIVE R4 ==="
Write-Host "MODE: NO_RECURSION_EXACT_V17_6E_YAML_COMPAT"
Write-Host "ROOT: $Root"

$Dirs = @(
  "configs\v16\universe",
  "outputs\v16\read_center",
  "outputs\v16\universe",
  "outputs\v16\risk",
  "outputs\v16\review",
  "outputs\v16\health",
  "outputs\v17\ops",
  "outputs\v17\raw105_decision",
  "outputs\v17\raw_universe_audit",
  "outputs\v17\price",
  "outputs\v17\manual_daily",
  "state\v16",
  "state\v17",
  "state\v18"
)

foreach ($d in $Dirs) {
    $p = Join-Path $Root $d
    if (-not (Test-Path $p)) {
        New-Item -ItemType Directory -Path $p -Force | Out-Null
    }
}

$SourceCandidates = @(
    (Join-Path $Root "state\v18\raw105_universe_for_factor_lab.csv"),
    (Join-Path $Root "outputs\v17\price\v17_6E_screened_universe_tickers.csv"),
    (Join-Path $Root "outputs\v17\raw105_decision\v17_8A_raw105_full_decision_daily.csv")
)

$Source = $null
foreach ($s in $SourceCandidates) {
    if (Test-Path $s) {
        $Source = $s
        break
    }
}

if (-not $Source) {
    throw "No available universe source for V16 compat shim."
}

$Raw = Import-Csv $Source
$TickerCol = $null

foreach ($c in @("ticker", "Ticker", "symbol", "Symbol")) {
    if ($Raw.Count -gt 0 -and ($Raw[0].PSObject.Properties.Name -contains $c)) {
        $TickerCol = $c
        break
    }
}

if (-not $TickerCol) {
    throw "No ticker-like column found in source: $Source"
}

$tickers = @()
foreach ($r in $Raw) {
    $t = [string]$r.$TickerCol
    if ($t -and $t.Trim().Length -gt 0) {
        $tickers += $t.Trim().ToUpper()
    }
}

$tickers = $tickers | Sort-Object -Unique

if ($tickers.Count -lt 50) {
    throw "Compat universe ticker count too small: $($tickers.Count)"
}

$Rows = @()
$i = 0
foreach ($t in $tickers) {
    $i += 1
    $Rows += [pscustomobject]@{
        rank = $i
        ticker = $t
        symbol = $t
        name = $t
        bucket = "V18_RAW105_COMPAT"
        decision = "REVIEW_ONLY"
        action = "REVIEW_ONLY"
        restriction = "COMPAT_NO_DIRECT_TRADE"
        source = "V18_RAW105_COMPAT"
        source_file = $Source
        run_time_jst = (Get-Date -Format "yyyy-MM-dd HH:mm:ss")
        compat_status = "OK_NON_RECURSIVE_EXACT_V17_6E_YAML"
    }
}

$TopRows = $Rows | Select-Object -First 20

$OutRaw = Join-Path $Root "outputs\v16\universe\V16_FULL_UNIVERSE_RAW.csv"
$OutScreened = Join-Path $Root "outputs\v16\universe\V16_FULL_UNIVERSE_SCREENED.csv"
$OutSelected = Join-Path $Root "outputs\v16\universe\V16_FULL_UNIVERSE_SELECTED_FOR_EXECUTION.csv"
$OutTop = Join-Path $Root "outputs\v16\universe\V16_SECOND_STAGE_TOP_CANDIDATES.csv"
$OutReview = Join-Path $Root "outputs\v16\review\V16_FULL_CANDIDATE_REVIEW.csv"
$OutGate = Join-Path $Root "outputs\v16\universe\V16_DAILY_FULL_UNIVERSE_GATE.md"
$ReadFirst = Join-Path $Root "outputs\v16\read_center\V16_COMPAT_FULL_UNIVERSE_READ_FIRST.txt"
$Proof = Join-Path $Root "outputs\v16\read_center\v16_compat_full_universe_proof.csv"
$V17TickerFile = Join-Path $Root "outputs\v17\price\v17_6E_screened_universe_tickers.csv"

$Rows | Export-Csv $OutRaw -NoTypeInformation -Encoding UTF8
$Rows | Export-Csv $OutScreened -NoTypeInformation -Encoding UTF8
$Rows | Export-Csv $OutSelected -NoTypeInformation -Encoding UTF8
$TopRows | Export-Csv $OutTop -NoTypeInformation -Encoding UTF8
$TopRows | Export-Csv $OutReview -NoTypeInformation -Encoding UTF8

$TickerRows = foreach ($t in $tickers) {
    [pscustomobject]@{
        ticker = $t
        symbol = $t
        run_time_jst = (Get-Date -Format "yyyy-MM-dd HH:mm:ss")
        source_file = $Source
        compat_status = "OK_V18_RAW105_TO_V17_SCREENED_TICKERS"
    }
}
$TickerRows | Export-Csv $V17TickerFile -NoTypeInformation -Encoding UTF8

$YamlScreened = Join-Path $Root "configs\v16\universe\us_full_screened_generated.yaml"
$YamlSecond = Join-Path $Root "configs\v16\universe\us_full_second_stage_generated.yaml"

# Exact format required by run_v17_6E_screened_universe_latest_price_audit.py:
# tickers:
#   - AAPL
#   - ACLS
$YamlLines = @()
$YamlLines += "tickers:"
foreach ($t in $tickers) {
    $YamlLines += "  - $t"
}
Set-Content -Path $YamlScreened -Value $YamlLines -Encoding UTF8

$YamlTopLines = @()
$YamlTopLines += "tickers:"
foreach ($t in ($tickers | Select-Object -First 20)) {
    $YamlTopLines += "  - $t"
}
Set-Content -Path $YamlSecond -Value $YamlTopLines -Encoding UTF8

$ProofRows = @(
    [pscustomobject]@{ key = "STATUS"; value = "OK_V16_COMPAT_FULL_UNIVERSE_NON_RECURSIVE_R4" },
    [pscustomobject]@{ key = "MODE"; value = "NO_RECURSION_EXACT_V17_6E_YAML_COMPAT" },
    [pscustomobject]@{ key = "SOURCE"; value = $Source },
    [pscustomobject]@{ key = "TICKER_COUNT"; value = $tickers.Count },
    [pscustomobject]@{ key = "SCREENED_ROWS"; value = $Rows.Count },
    [pscustomobject]@{ key = "SECOND_STAGE_ROWS"; value = $TopRows.Count },
    [pscustomobject]@{ key = "YAML_FORMAT"; value = "TICKERS_COLON_DASH_SYMBOL" },
    [pscustomobject]@{ key = "OFFICIAL_DECISION_IMPACT"; value = "NONE" },
    [pscustomobject]@{ key = "CALLS_V17_8A"; value = "NO" },
    [pscustomobject]@{ key = "CALLS_V17_6F"; value = "NO" }
)

$ProofRows | Export-Csv $Proof -NoTypeInformation -Encoding UTF8

$GateText = @"
# V16 Full Universe Compat Shim R4

生成时间：$Stamp

STATUS: OK_V16_COMPAT_FULL_UNIVERSE_NON_RECURSIVE_R4

MODE: NO_RECURSION_EXACT_V17_6E_YAML_COMPAT

SOURCE: $Source

TICKER_COUNT: $($tickers.Count)

SCREENED_ROWS: $($Rows.Count)

SECOND_STAGE_ROWS: $($TopRows.Count)

YAML_FORMAT: TICKERS_COLON_DASH_SYMBOL

OFFICIAL_DECISION_IMPACT: NONE

说明：

- 这是 V18 active chain 的旧 V16 入口兼容层。
- 本脚本不调用 V17_8A / V17_7G / V17_6F，避免递归。
- YAML 使用 V17.6E parser 源码要求的格式：tickers: + "  - TICKER"。
- action/restriction 固定为 REVIEW_ONLY / COMPAT_NO_DIRECT_TRADE，避免兼容层直接产生交易执行含义。
"@

Set-Content -Path $OutGate -Value $GateText -Encoding UTF8

$ReadText = @"
V16 FULL UNIVERSE COMPAT SHIM R4 READ FIRST

STATUS:
OK_V16_COMPAT_FULL_UNIVERSE_NON_RECURSIVE_R4

MODE:
NO_RECURSION_EXACT_V17_6E_YAML_COMPAT

SOURCE:
$Source

TICKER_COUNT:
$($tickers.Count)

SCREENED_ROWS:
$($Rows.Count)

SECOND_STAGE_ROWS:
$($TopRows.Count)

YAML_FORMAT:
TICKERS_COLON_DASH_SYMBOL

OUTPUTS:
$OutRaw
$OutScreened
$OutSelected
$OutTop
$OutReview
$V17TickerFile
$YamlScreened
$YamlSecond
$OutGate
$Proof

OFFICIAL_DECISION_IMPACT:
NONE

CALLS_V17_8A:
NO

CALLS_V17_6F:
NO
"@

Set-Content -Path $ReadFirst -Value $ReadText -Encoding UTF8

Write-Host "STATUS: OK_V16_COMPAT_FULL_UNIVERSE_NON_RECURSIVE_R4"
Write-Host "TICKER_COUNT: $($tickers.Count)"
Write-Host "SCREENED_ROWS: $($Rows.Count)"
Write-Host "SECOND_STAGE_ROWS: $($TopRows.Count)"
Write-Host "YAML_FORMAT: TICKERS_COLON_DASH_SYMBOL"
Write-Host "READ_FIRST: $ReadFirst"
Write-Host "GATE: $OutGate"
Write-Host "PROOF: $Proof"
Write-Host "=== V16 FULL UNIVERSE COMPAT SHIM R4 DONE ==="
